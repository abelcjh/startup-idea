WORKOS_CLIENT_ID=

# === Stripe [OPTIONAL] ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Unkey (API Key Mgmt) [OPTIONAL] ===
UNKEY_ROOT_KEY=
UNKEY_API_ID=

# === PostHog [OPTIONAL] ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# === Resend [OPTIONAL] ===
RESEND_API_KEY=

# === Sentry [OPTIONAL] ===
SENTRY_DSN=

# === LangSmith [OPTIONAL] ===
