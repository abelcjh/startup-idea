{
  "name": "product-os",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev dev:worker",
    "dev:web": "turbo run dev --filter=@product-os/web",
    "dev:api": "turbo run dev --filter=@product-os/api",
    "dev:worker": "turbo run dev:worker --filter=@product-os/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "db:generate": "turbo run db:generate --filter=@product-os/web",
    "db:push": "turbo run db:push --filter=@product-os/web",
    "db:seed": "turbo run db:seed --filter=@product-os/web",
    "db:reset": "pnpm db:push && pnpm db:seed",
    "setup": "pnpm install && pnpm docker:up && pnpm db:push && pnpm db:generate && pnpm db:seed"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
